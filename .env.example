# --- AI (required) ---------------------------------------------------------
# Provider is swappable without code changes. If AI_PROVIDER is unset, the first
# provider below with a key set wins, in this priority order:
#   ollama > cerebras > groq > openrouter > nvidia > cloudflare > anthropic > openai
# Set just one key to get going. All are OpenAI-compatible except anthropic.
# AI_PROVIDER=ollama           # force a provider
# AI_MODEL=gpt-oss:120b        # optional model id override

OLLAMA_API_KEY=                # Ollama Cloud (default) — ollama.com/settings/keys
CEREBRAS_API_KEY=              # cloud.cerebras.ai
GROQ_API_KEY=                  # console.groq.com/keys
OPENROUTER_API_KEY=            # openrouter.ai/keys
NVIDIA_NIM_API_KEY=            # build.nvidia.com
# Cloudflare Workers AI needs BOTH the token and the account id.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- GitHub (optional) ------------------------------------------------------
# Raises unauthenticated API rate limits when ingesting public repos.
# GITHUB_TOKEN=

# --- Deferred infra (add when the slice that needs it lands) ----------------
# DATABASE_URL=                        # Neon Postgres + Drizzle
# UPSTASH_VECTOR_REST_URL=             # RAG vector store
# UPSTASH_VECTOR_REST_TOKEN=
# UPSTASH_REDIS_REST_URL=              # rate limiting / cache
# UPSTASH_REDIS_REST_TOKEN=
# BETTER_AUTH_SECRET=                  # auth (private repos)
